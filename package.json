{
  "name": "cyrillic-latin-transliteration",
  "version": "1.0.1",
  "description": "Transliterate between Cyrillic and Latin scripts. Zero dependencies.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "transliteration",
    "cyrillic",
    "latin",
    "russian",
    "cyrillic-latin",
    "latin-cyrillic"
  ],
  "author": "MaxGrushevsky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaxGrushevsky/cyrillic-latin-transliteration.git"
  },
  "homepage": "https://github.com/MaxGrushevsky/cyrillic-latin-transliteration#readme",
  "bugs": {
    "url": "https://github.com/MaxGrushevsky/cyrillic-latin-transliteration/issues"
  },
  "sideEffects": false,
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=14"
  }
}
